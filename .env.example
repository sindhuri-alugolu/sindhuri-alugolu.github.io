# Copy to .env.local for local development (never commit .env.local)
# cp .env.example .env.local

# Admin sign-in (local dev only — on GitHub Pages use repository secret ADMIN_PIN)
ADMIN_PIN=your-pin-here
NEXT_PUBLIC_ADMIN_PIN=your-pin-here

# Site URL
NEXT_PUBLIC_SITE_URL=https://sindhuri-alugolu.github.io

# GitHub repo for admin Save (owner/repo)
NEXT_PUBLIC_GITHUB_REPO=sindhuri-alugolu/sindhuri-alugolu.github.io

# Optional: local testing of GitHub Save (use repository secret ADMIN_GITHUB_TOKEN in CI instead)
# NEXT_PUBLIC_GITHUB_TOKEN=
